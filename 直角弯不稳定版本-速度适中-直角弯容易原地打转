#include <Wire.h>
#include <ADS1115_WE.h>

ADS1115_WE ads = ADS1115_WE(0x48);

// ====================================================
// 调试开关（注释掉关闭串口输出）
// ====================================================
#define DEBUG_SERIAL

// ====================================================
// 电机PWM引脚
// ====================================================
const int enablePin1 = 10;
const int enablePin2 = 9;

// ====================================================
// 电机方向引脚
// ====================================================
const int in1Pin = 4;
const int in2Pin = 5;
const int in3Pin = 2;
const int in4Pin = 3;

// ====================================================
// ADS1115阈值
// ====================================================
const int thresholds[3] = {
    12700,  // 左: 白~6500 / 黑~18890
    9785,   // 中: 白~1350 / 黑~18220
    11255   // 右: 白~5260 / 黑~17250
};

// ====================================================
// 传感器状态
// ====================================================
int irSensorDigital[3];
int irSensors = B000;

// ====================================================
// 基础速度
// ====================================================
const int baseSpeed = 90;

// ====================================================
// 死区阈值
// ====================================================
const int deadband = 8;

// ====================================================
// 正常模式PID参数
// ====================================================
const float Kp_normal = 0.45;
const float Ki_normal = 0.00;
const float Kd_normal = 2.5;

// ====================================================
// 直角弯PID参数
// ====================================================
const float Kp_sharp = 0.25;
const float Ki_sharp = 0.02;
const float Kd_sharp = 1.5;

// ====================================================
// PID变量
// ====================================================
float error = 0;
float lastError = 0;
float integral = 0;
float derivative = 0;
float pid = 0;

// ====================================================
// 直角弯状态锁存
// ====================================================
bool turningHard = false;
int hardTurnDir = 0;  // 0=无, 1=右转(B001), -1=左转(B100)

// ====================================================
// 电机速度
// ====================================================
int leftMotorSpeed = 0;
int rightMotorSpeed = 0;

// ====================================================
// 读取ADS1115通道（使用静态数组优化）
// ====================================================
int readADS(byte ch) {
    static const ADS1115_MUX channels[3] = {
        ADS1115_COMP_0_GND,  // 通道0
        ADS1115_COMP_1_GND,  // 通道1
        ADS1115_COMP_2_GND   // 通道2
    };
    
    ads.setCompareChannels(channels[ch]);
    ads.startSingleMeasurement();
    while(ads.isBusy()) {}
    return ads.getRawResult();
}

// ====================================================
// 初始化
// ====================================================
void setup() {
    #ifdef DEBUG_SERIAL
    Serial.begin(115200);
    #endif

    pinMode(enablePin1, OUTPUT);
    pinMode(enablePin2, OUTPUT);
    pinMode(in1Pin, OUTPUT);
    pinMode(in2Pin, OUTPUT);
    pinMode(in3Pin, OUTPUT);
    pinMode(in4Pin, OUTPUT);

    Wire.begin();

    if(!ads.init()) {
        #ifdef DEBUG_SERIAL
        Serial.println("ADS1115 ERROR");
        #endif
        while(1);
    }

    ads.setVoltageRange_mV(ADS1115_RANGE_6144);
    ads.setConvRate(ADS1115_860_SPS);

    #ifdef DEBUG_SERIAL
    Serial.println("ADS1115 READY");
    #endif

    // 初始化电机为刹车状态
    StopMotors();
}

// ====================================================
// 主循环
// ====================================================
void loop() {
    Scan();
    CalculateError();
    PID_Control();
    Drive(leftMotorSpeed, rightMotorSpeed);
}

// ====================================================
// 扫描红外传感器
// ====================================================
void Scan() {
    irSensors = B000;

    // 传感器通道映射:
    // ADS A2 ← 左传感器
    // ADS A1 ← 中间传感器
    // ADS A0 ← 右传感器
    int rawLeft  = readADS(2);
    int rawMid   = readADS(1);
    int rawRight = readADS(0);

    int raw[3] = {rawLeft, rawMid, rawRight};

    for(int i = 0; i < 3; i++) {
        irSensorDigital[i] = (raw[i] >= thresholds[i]) ? 1 : 0;
        irSensors |= (irSensorDigital[i] << (2 - i));
    }

    // 定时输出调试信息（每80ms一次）
    #ifdef DEBUG_SERIAL
    static unsigned long lastPrint = 0;
    if(millis() - lastPrint > 80) {
        Serial.print("L=");
        Serial.print(rawLeft);
        Serial.print(" M=");
        Serial.print(rawMid);
        Serial.print(" R=");
        Serial.print(rawRight);
        Serial.print(" S=B");
        Serial.print(irSensors, BIN);
        Serial.print(" E=");
        Serial.print(error);
        Serial.print(" LSPD=");
        Serial.print(leftMotorSpeed);
        Serial.print(" RSPD=");
        Serial.print(rightMotorSpeed);
        Serial.print(" T=");
        Serial.println(turningHard ? "HARD" : "NORM");
        lastPrint = millis();
    }
    #endif
}

// ====================================================
// 状态转误差
// ====================================================
void CalculateError() {
    switch(irSensors) {
        case B010:  // 中间看到线
            error = 0;
            break;

        case B110:  // 左+中看到线
            error = -40;
            break;

        case B100:  // 仅左看到线
            error = -80;
            break;

        case B011:  // 中+右看到线
            error = 40;
            break;

        case B001:  // 仅右看到线
            error = 80;
            break;

        case B000:  // 完全丢线
            if(abs(lastError) < 40) {
                // 直道轻微丢线，温和纠偏，避免原地打转
                error = (lastError < 0) ? -60 : 60;
            } else if(lastError < 0) {
                error = -110;  // 弯道丢线，强力纠偏
            } else {
                error = 110;
            }
            break;

        case B111:  // 全部看到线（十字路口等）
            error = 0;
            break;

        default:
            error = lastError;
    }
}

// ====================================================
// PID控制
// ====================================================
void PID_Control() {
    derivative = error - lastError;
    derivative = constrain(derivative, -60, 60);  // 限制冲击，防止直道丢线时自转

    // ============================================
    // 直角弯检测与状态锁存（带方向记忆 + 退出冷却）
    // ============================================
    bool isLostInTurn = (irSensors == B000 && abs(lastError) >= 80);

    // 退出冷却：防止退出后立即再次进入导致震荡
    static unsigned long cooldownUntil = 0;
    bool inCooldown = (millis() < cooldownUntil);

    if(!turningHard) {
        // 不在直角弯中，检测是否进入（冷却期内禁止进入）
        if(!inCooldown) {
            if(irSensors == B100) {
                turningHard = true;
                hardTurnDir = -1;  // 左直角弯
            } else if(irSensors == B001) {
                turningHard = true;
                hardTurnDir = 1;   // 右直角弯
            }
        }
    } else {
        // 已在直角弯中
        bool exitTurn = false;
        if(irSensors == B010 || irSensors == B011 || irSensors == B110 || irSensors == B111) {
            // 中间传感器重新看到线，正常退出
            exitTurn = true;
        } else if((irSensors == B100 && hardTurnDir == 1) ||
                  (irSensors == B001 && hardTurnDir == -1)) {
            // 对侧传感器看到线 → 过弯完成，退出（防止反向误判）
            exitTurn = true;
        }

        if(exitTurn) {
            turningHard = false;
            hardTurnDir = 0;
            cooldownUntil = millis() + 300;  // 300ms冷却期
        }
        // 同向传感器或B000 → 保持当前方向和状态
    }

    // 直角弯超时保护：超过800ms强制退出，防止振荡打转
    static unsigned long hardTurnStart = 0;
    static bool hardTurnTimerRunning = false;
    if(turningHard && !hardTurnTimerRunning) {
        hardTurnStart = millis();
        hardTurnTimerRunning = true;
    }
    if(!turningHard) {
        hardTurnTimerRunning = false;
    }
    if(hardTurnTimerRunning && (millis() - hardTurnStart > 800)) {
        turningHard = false;
        hardTurnTimerRunning = false;
        integral = 0;
    }

    bool useSharpPID = turningHard || isLostInTurn;

    // ============================================
    // 模式切换时重置积分
    // ============================================
    static bool wasSharpLastLoop = false;
    if(useSharpPID != wasSharpLastLoop) {
        integral = 0;
    }
    wasSharpLastLoop = useSharpPID;

    // ============================================
    // 积分累加（仅在直角弯或小误差时）
    // ============================================
    if(useSharpPID || abs(error) < 60) {
        integral += error;
    } else {
        integral = 0;  // 大误差时清零积分，防止积分饱和
    }

    integral = constrain(integral, -300, 300);

    // ============================================
    // 选择PID参数与基础速度
    // ============================================
    float currentKp, currentKi, currentKd;
    int currentBaseSpeed;

    if(useSharpPID) {
        currentKp = Kp_sharp;
        currentKi = Ki_sharp;
        currentKd = Kd_sharp;
        currentBaseSpeed = 45;
    } else {
        currentKp = Kp_normal;
        currentKi = Ki_normal;
        currentKd = Kd_normal;

        // 根据误差调整基础速度
        int absErr = abs(error);
        if(absErr >= 110) {
            currentBaseSpeed = 30;  // 完全丢线
        } else if(absErr >= 40) {
            currentBaseSpeed = 55;  // 一般弯道
        } else {
            currentBaseSpeed = baseSpeed;  // 直线
        }
    }

    // ============================================
    // 计算PID输出
    // ============================================
    pid = currentKp * error + currentKi * integral + currentKd * derivative;
    lastError = error;

    // ============================================
    // 计算电机速度
    // ============================================
    leftMotorSpeed = constrain(currentBaseSpeed + pid, -255, 255);
    rightMotorSpeed = constrain(currentBaseSpeed - pid, -255, 255);
}

// ====================================================
// 驱动电机（带死区与刹车）
// ====================================================
void Drive(int leftSpeed, int rightSpeed) {
    // 右电机 (enablePin1, in1Pin, in2Pin)
    if(abs(rightSpeed) < deadband) {
        // 滑行（断电，不刹车）
        analogWrite(enablePin1, 0);
    } else if(rightSpeed > 0) {
        // 正转
        digitalWrite(in1Pin, HIGH);
        digitalWrite(in2Pin, LOW);
        analogWrite(enablePin1, rightSpeed);
    } else {
        // 反转
        digitalWrite(in1Pin, LOW);
        digitalWrite(in2Pin, HIGH);
        analogWrite(enablePin1, -rightSpeed);
    }

    // 左电机 (enablePin2, in3Pin, in4Pin)
    if(abs(leftSpeed) < deadband) {
        // 滑行（断电，不刹车）
        analogWrite(enablePin2, 0);
    } else if(leftSpeed > 0) {
        // 正转
        digitalWrite(in3Pin, HIGH);
        digitalWrite(in4Pin, LOW);
        analogWrite(enablePin2, leftSpeed);
    } else {
        // 反转
        digitalWrite(in3Pin, LOW);
        digitalWrite(in4Pin, HIGH);
        analogWrite(enablePin2, -leftSpeed);
    }
}

// ====================================================
// 停止电机
// ====================================================
void StopMotors() {
    digitalWrite(in1Pin, LOW);
    digitalWrite(in2Pin, LOW);
    digitalWrite(in3Pin, LOW);
    digitalWrite(in4Pin, LOW);
    analogWrite(enablePin1, 0);
    analogWrite(enablePin2, 0);
}
