#include <Wire.h>
#include <ADS1115_WE.h>
// ==================== 电机引脚测试代码（修复版） ====================

// 引脚定义
const int enablePin1 = 9;  // 左电机速度 PWM
const int enablePin2 = 10;   // 右电机速度 PWM

const int in1Pin = 2;       // 左电机方向引脚1
const int in2Pin = 3;       // 左电机方向引脚2
const int in3Pin = 4;       // 右电机方向引脚1
const int in4Pin = 5;       // 右电机方向引脚2

// ==================== ADS1115 ====================
ADS1115_WE ads = ADS1115_WE(0x48);

// 传感器阈值: {左(A2), 中(A1), 右(A0)}
int thresholds[3] = {12700, 9785, 11255};

// ==================== PID ====================
float Kp = 0.45, Ki = 0.00, Kd = 2.5;
int error = 0, lastError = 0;
int baseSpeed = 60;  // 基础速度 (0~255)

int irSensors = 0;    // 3-bit 传感器状态 [左|中|右]

// ==================== 初始化 ====================
void setup() {
  Serial.begin(115200);

  // 电机引脚
  pinMode(enablePin1, OUTPUT);
  pinMode(enablePin2, OUTPUT);
  pinMode(in1Pin, OUTPUT);
  pinMode(in2Pin, OUTPUT);
  pinMode(in3Pin, OUTPUT);
  pinMode(in4Pin, OUTPUT);

  // 初始停止
  digitalWrite(in1Pin, LOW);
  digitalWrite(in2Pin, LOW);
  digitalWrite(in3Pin, LOW);
  digitalWrite(in4Pin, LOW);
  analogWrite(enablePin1, 0);
  analogWrite(enablePin2, 0);

  // ADS1115 初始化
  Wire.begin();
  if (!ads.init()) {
    Serial.println("ADS1115 init failed!");
    while (1);
  }
  ads.setVoltageRange_mV(ADS1115_RANGE_6144);
  ads.setMeasureMode(ADS1115_CONTINUOUS);

  delay(1000);
  Serial.println("Ready");
}

// ==================== 读取传感器 ====================
void readSensors() {
  int leftVal, midVal, rightVal;
  int leftBit = 0, midBit = 0, rightBit = 0;

  // ADS A0 → 右传感器
  ads.setCompareChannels(ADS1115_COMP_0_GND);
  delay(2);
  rightVal = ads.getRawResult();

  // ADS A1 → 中间传感器
  ads.setCompareChannels(ADS1115_COMP_1_GND);
  delay(2);
  midVal = ads.getRawResult();

  // ADS A2 → 左传感器
  ads.setCompareChannels(ADS1115_COMP_2_GND);
  delay(2);
  leftVal = ads.getRawResult();

  // 低于阈值 = 检测到黑线
  if (leftVal < thresholds[0])  leftBit = 1;
  if (midVal < thresholds[1])   midBit = 1;
  if (rightVal < thresholds[2]) rightBit = 1;

  irSensors = (leftBit << 2) | (midBit << 1) | rightBit;
}

// ==================== 状态 → 误差 ====================
void calculateError() {
  lastError = error;

  switch (irSensors) {
    case B010: error = 0;              break;  // 正中 → 直走
    case B110: error = -40;            break;  // 偏左 → 左转
    case B100: error = -80;            break;  // 更左 → 更急左转
    case B011: error = 40;             break;  // 偏右 → 右转
    case B001: error = 80;             break;  // 更右 → 更急右转
    case B000: error = (lastError < 0) ? -110 : 110;  break;  // 丢线 → 按上次方向继续找
    case B111: error = 0;              break;  // 十字/全黑 → 直走
    default:   error = lastError;      break;  // 其他情况保持
  } 
}

// ==================== PID + 电机驱动 ====================
void motorDrive() {
  float derivative = error - lastError;
  float correction = Kp * error + Kd * derivative;  // Ki=0 省略积分项

  int leftSpeed  = constrain(baseSpeed + correction, 0, 255);
  int rightSpeed = constrain(baseSpeed - correction, 0, 255);

  // 前进
  digitalWrite(in1Pin, HIGH);
  digitalWrite(in2Pin, LOW);
  digitalWrite(in3Pin, HIGH);
  digitalWrite(in4Pin, LOW);

  analogWrite(enablePin1, leftSpeed);
  analogWrite(enablePin2, rightSpeed);
}

// ==================== 主循环 ====================
void loop() {
  readSensors();
  calculateError();
  motorDrive();

  // 调试输出
  Serial.print("State:");
  Serial.print(irSensors, BIN);
  Serial.print(" Error:");
  Serial.println(error);
}
