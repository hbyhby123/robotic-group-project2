#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME280.h>

// ===== BME280 传感器 =====
Adafruit_BME280 bme;
#define SEALEVELPRESSURE_HPA (1013.25)

// ===== MPU6050 传感器 =====
#define MPU6050_ADDR 0x68   // MPU6050 的 I2C 地址

// ===== 电机控制引脚 =====
const int enA = 10, enB = 9;
const int in1 = 4, in2 = 5, in3 = 2, in4 = 3;

// ===== 模式枚举 =====
enum CarState {
    STATE_STATIONARY,   // 静止模式（车轮停转）
    STATE_LIFTED,       // 抬升模式（车轮转动）
    STATE_PUTDOWN       // 放下模式（车轮停转）
};

// ===== 全局状态变量 =====
unsigned long lastDisp = 0;      // 上次显示时间
unsigned long lastDet = 0;       // 上次检测时间
CarState state = STATE_STATIONARY;  // 初始为静止模式

// ===== MPU6050 校准基准值 =====
float accOffsetX = 0, accOffsetY = 0, accOffsetZ = 0;
float gyroOffsetX = 0, gyroOffsetY = 0, gyroOffsetZ = 0;

// ===== 陀螺仪低通滤波状态 =====
float gyroFiltX = 0, gyroFiltY = 0, gyroFiltZ = 0;
const float GYRO_ALPHA = 0.15;     // 低通系数（越小越平滑，越大越灵敏）
const float GYRO_DEADBAND = 0.5;   // 死区阈值 °/s（低于此值归零）

// ===== 切换冷却 =====
unsigned long lastSwitch = 0;    // 上次状态切换的时间
const unsigned int COOLDOWN_MS = 2000;  // 切换冷却时间（两次切换至少间隔 2s）

// ==========================================================
//  MPU6050 底层读写函数
// ==========================================================
void writeReg(uint8_t addr, uint8_t reg, uint8_t val) {
    Wire.beginTransmission(addr);
    Wire.write(reg);
    Wire.write(val);
    Wire.endTransmission();
}

void readRegs(uint8_t addr, uint8_t reg, uint8_t* buf, uint8_t len) {
    Wire.beginTransmission(addr);
    Wire.write(reg);
    Wire.endTransmission(false);
    Wire.requestFrom(addr, len);
    for (uint8_t i = 0; i < len; i++) {
        buf[i] = Wire.read();
    }
}

// ==========================================================
//  MPU6050 初始化及数据读取
// ==========================================================
void initMPU6050() {
    // 唤醒 MPU6050（退出休眠模式）
    writeReg(MPU6050_ADDR, 0x6B, 0x00);
    delay(100);
    // 配置加速度计为 ±2g 量程
    writeReg(MPU6050_ADDR, 0x1C, 0x00);
    // 配置陀螺仪为 ±250°/s 量程
    writeReg(MPU6050_ADDR, 0x1B, 0x00);
}

void readAccRaw(float &ax, float &ay, float &az) {
    uint8_t d[6];
    readRegs(MPU6050_ADDR, 0x3B, d, 6);
    ax = ((int16_t)((d[0] << 8) | d[1])) / 16384.0;
    ay = ((int16_t)((d[2] << 8) | d[3])) / 16384.0;
    az = ((int16_t)((d[4] << 8) | d[5])) / 16384.0;
}

void readGyroRaw(float &gx, float &gy, float &gz) {
    uint8_t d[6];
    readRegs(MPU6050_ADDR, 0x43, d, 6);
    gx = ((int16_t)((d[0] << 8) | d[1])) / 131.0;
    gy = ((int16_t)((d[2] << 8) | d[3])) / 131.0;
    gz = ((int16_t)((d[4] << 8) | d[5])) / 131.0;
}

void readAcc(float &ax, float &ay, float &az) {
    readAccRaw(ax, ay, az);
    ax -= accOffsetX;
    ay -= accOffsetY;
    az -= accOffsetZ;
}

void readGyro(float &gx, float &gy, float &gz) {
    float rawX, rawY, rawZ;
    readGyroRaw(rawX, rawY, rawZ);

    // 减去零偏
    rawX -= gyroOffsetX;
    rawY -= gyroOffsetY;
    rawZ -= gyroOffsetZ;

    // 一阶低通滤波（指数移动平均）
    gyroFiltX = GYRO_ALPHA * rawX + (1.0 - GYRO_ALPHA) * gyroFiltX;
    gyroFiltY = GYRO_ALPHA * rawY + (1.0 - GYRO_ALPHA) * gyroFiltY;
    gyroFiltZ = GYRO_ALPHA * rawZ + (1.0 - GYRO_ALPHA) * gyroFiltZ;

    // 死区滤波：低于阈值的微小抖动归零
    gx = (abs(gyroFiltX) < GYRO_DEADBAND) ? 0.0 : gyroFiltX;
    gy = (abs(gyroFiltY) < GYRO_DEADBAND) ? 0.0 : gyroFiltY;
    gz = (abs(gyroFiltZ) < GYRO_DEADBAND) ? 0.0 : gyroFiltZ;
}

// ==========================================================
//  MPU6050 基准值校准（需在静止状态下调用）
// ==========================================================
void calibrateMPU6050() {
    const int samples = 200;
    float sumAx = 0, sumAy = 0, sumAz = 0;
    float sumGx = 0, sumGy = 0, sumGz = 0;

    Serial.print("正在校准 MPU6050（采集 ");
    Serial.print(samples);
    Serial.println(" 个样本，请保持静止...）");

    for (int i = 0; i < samples; i++) {
        float ax, ay, az, gx, gy, gz;
        readAccRaw(ax, ay, az);
        readGyroRaw(gx, gy, gz);
        sumAx += ax;
        sumAy += ay;
        sumAz += az;
        sumGx += gx;
        sumGy += gy;
        sumGz += gz;
        delay(5);
    }

    // 加速度计：静止时 X/Y 应为 0，Z 应为 1g
    accOffsetX = sumAx / samples;          // X 偏移
    accOffsetY = sumAy / samples;          // Y 偏移
    accOffsetZ = sumAz / samples - 1.0;    // Z 偏移（减去重力 1g）

    // 陀螺仪：静止时全部应为 0
    gyroOffsetX = sumGx / samples;
    gyroOffsetY = sumGy / samples;
    gyroOffsetZ = sumGz / samples;

    Serial.println("MPU6050 校准完成：");
    Serial.print("  加速度计偏移: X=");  Serial.print(accOffsetX, 4);
    Serial.print("  Y=");              Serial.print(accOffsetY, 4);
    Serial.print("  Z=");              Serial.println(accOffsetZ, 4);
    Serial.print("  陀螺仪偏移:   X=");  Serial.print(gyroOffsetX, 3);
    Serial.print("  Y=");              Serial.print(gyroOffsetY, 3);
    Serial.print("  Z=");              Serial.println(gyroOffsetZ, 3);
}

// ==========================================================
//  电机控制
// ==========================================================
void motor(bool run) {
    if (run) {
        // 正转（速度 100）
        digitalWrite(in1, HIGH);
        digitalWrite(in2, LOW);
        analogWrite(enA, 100);
        digitalWrite(in3, HIGH);
        digitalWrite(in4, LOW);
        analogWrite(enB, 100);
    } else {
        // 停止
        digitalWrite(in1, LOW);
        digitalWrite(in2, LOW);
        analogWrite(enA, 0);
        digitalWrite(in3, LOW);
        digitalWrite(in4, LOW);
        analogWrite(enB, 0);
    }
}

// ==========================================================
//  setup()
// ==========================================================
void setup() {
    Serial.begin(9600);
    delay(500);

    // 电机引脚配置
    pinMode(enA, OUTPUT);
    pinMode(enB, OUTPUT);
    pinMode(in1, OUTPUT);
    pinMode(in2, OUTPUT);
    pinMode(in3, OUTPUT);
    pinMode(in4, OUTPUT);

    Wire.begin();

    // 初始化 BME280
    if (!bme.begin(0x76)) {
        Serial.println("BME280 初始化失败！");
        while (1);
    }

    // 初始化 MPU6050
    initMPU6050();

    // 校准 MPU6050 基准值（此时请保持机器人静止放在平面上）
    calibrateMPU6050();

    Serial.println("系统启动完成");
    motor(false);   // 确保初始电机停止
}

// ==========================================================
//  loop()
// ==========================================================
void loop() {
    // ----- 1. 模式检测（每 50ms 一次） -----
    if (millis() - lastDet >= 50) {
        float ax, ay, az;
        readAcc(ax, ay, az);

        // ===== 冷却期内跳过检测 =====
        if (millis() - lastSwitch >= COOLDOWN_MS) {

            switch (state) {

                case STATE_STATIONARY:
                    // 静止模式：az > 1.4 则进入抬升模式
                    if (az > 1.4) {
                        state = STATE_LIFTED;
                        lastSwitch = millis();
                        Serial.println(">>> 检测到抬升，车轮开始转动 <<<");
                    }
                    break;

                case STATE_LIFTED:
                    // 抬升模式：az < 0.6 则进入放下模式
                    if (az < 0.6) {
                        state = STATE_PUTDOWN;
                        lastSwitch = millis();
                        Serial.println(">>> 检测到放下，车轮停止转动 <<<");
                    } else if (az > 1.4) {
                        // 重新确认抬升模式，重置冷却计时器，防止抖动误触发
                        lastSwitch = millis();
                        Serial.println(">>> 确认抬升，维持转动 <<<");
                    }
                    break;

                case STATE_PUTDOWN:
                    // 放下模式：az > 1.4 则再次进入抬升模式
                    if (az > 1.4) {
                        state = STATE_LIFTED;
                        lastSwitch = millis();
                        Serial.println(">>> 检测到抬升，车轮开始转动 <<<");
                    } else if (az < 0.6) {
                        // 重新确认放下模式，重置冷却计时器，防止抖动误触发
                        lastSwitch = millis();
                        Serial.println(">>> 确认放下，维持停止 <<<");
                    }
                    break;
            }
        }

        lastDet = millis();
    }

    // ----- 2. 传感器数据显示（每 500ms 一次） -----
    if (millis() - lastDisp >= 500) {
        float ax, ay, az, gx, gy, gz;
        readAcc(ax, ay, az);
        readGyro(gx, gy, gz);

        // ---- BME280 数据 ----
        Serial.print("[BME280] ");
        Serial.print("温度：");
        Serial.print(bme.readTemperature(), 1);
        Serial.print("°C，湿度：");
        Serial.print(bme.readHumidity(), 1);
        Serial.print("%，气压：");
        Serial.print(bme.readPressure() / 100.0, 1);
        Serial.println(" hPa");

        // ---- MPU6050 数据 ----
        Serial.print("[MPU6050] ");
        Serial.print("加速度计：X=");
        Serial.print(ax, 2);
        Serial.print("g，Y=");
        Serial.print(ay, 2);
        Serial.print("g，Z=");
        Serial.print(az, 2);
        Serial.print("g | 陀螺仪：X=");
        Serial.print(gx, 1);
        Serial.print("°/s，Y=");
        Serial.print(gy, 1);
        Serial.print("°/s，Z=");
        Serial.print(gz, 1);
        Serial.println("°/s");

        Serial.println("---");   // 分隔线
        lastDisp = millis();
    }

    // ----- 3. 根据模式控制电机 -----
    motor(state == STATE_LIFTED);
}
