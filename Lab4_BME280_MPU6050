#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME280.h>

// ===== BME280 传感器 =====
Adafruit_BME280 bme;
#define SEALEVELPRESSURE_HPA (1013.25)

// ===== MPU6050 传感器 =====
#define MPU6050_ADDR 0x68   // MPU6050 的 I2C 地址

// ===== 电机控制引脚 =====
const int enA = 10, enB = 9;
const int in1 = 4, in2 = 5, in3 = 2, in4 = 3;

// ===== 全局状态变量 =====
unsigned long lastDisp = 0;      // 上次显示时间
unsigned long lastDet = 0;       // 上次检测时间
bool lifted = false;             // 是否抬起状态
float lastAcc = 1.0;             // 上一次加速度模值

// ===== 防抖计数器 =====
unsigned int liftCnt = 0;        // 连续满足抬起条件的次数
unsigned int dropCnt = 0;        // 连续满足放下条件的次数
const unsigned int CNT_NEEDED = 3;  // 需要连续几次才切换状态（约 3×66ms = 200ms）

// ==========================================================
//  MPU6050 底层读写函数
// ==========================================================
void writeReg(uint8_t addr, uint8_t reg, uint8_t val) {
    Wire.beginTransmission(addr);
    Wire.write(reg);
    Wire.write(val);
    Wire.endTransmission();
}

void readRegs(uint8_t addr, uint8_t reg, uint8_t* buf, uint8_t len) {
    Wire.beginTransmission(addr);
    Wire.write(reg);
    Wire.endTransmission(false);
    Wire.requestFrom(addr, len);
    for (uint8_t i = 0; i < len; i++) {
        buf[i] = Wire.read();
    }
}

// ==========================================================
//  MPU6050 初始化及数据读取
// ==========================================================
void initMPU6050() {
    // 唤醒 MPU6050（退出休眠模式）
    writeReg(MPU6050_ADDR, 0x6B, 0x00);
    delay(100);
    // 配置加速度计为 ±2g 量程
    writeReg(MPU6050_ADDR, 0x1C, 0x00);
    // 配置陀螺仪为 ±250°/s 量程
    writeReg(MPU6050_ADDR, 0x1B, 0x00);
}

void readAcc(float &ax, float &ay, float &az) {
    uint8_t d[6];
    readRegs(MPU6050_ADDR, 0x3B, d, 6);
    ax = ((int16_t)((d[0] << 8) | d[1])) / 16384.0;
    ay = ((int16_t)((d[2] << 8) | d[3])) / 16384.0;
    az = ((int16_t)((d[4] << 8) | d[5])) / 16384.0;
}

void readGyro(float &gx, float &gy, float &gz) {
    uint8_t d[6];
    readRegs(MPU6050_ADDR, 0x43, d, 6);
    gx = ((int16_t)((d[0] << 8) | d[1])) / 131.0;
    gy = ((int16_t)((d[2] << 8) | d[3])) / 131.0;
    gz = ((int16_t)((d[4] << 8) | d[5])) / 131.0;
}

// ==========================================================
//  电机控制
// ==========================================================
void motor(bool run) {
    if (run) {
        // 正转（速度 100）
        digitalWrite(in1, HIGH);
        digitalWrite(in2, LOW);
        analogWrite(enA, 100);
        digitalWrite(in3, HIGH);
        digitalWrite(in4, LOW);
        analogWrite(enB, 100);
    } else {
        // 停止
        digitalWrite(in1, LOW);
        digitalWrite(in2, LOW);
        analogWrite(enA, 0);
        digitalWrite(in3, LOW);
        digitalWrite(in4, LOW);
        analogWrite(enB, 0);
    }
}

// ==========================================================
//  setup()
// ==========================================================
void setup() {
    Serial.begin(9600);
    delay(500);

    // 电机引脚配置
    pinMode(enA, OUTPUT);
    pinMode(enB, OUTPUT);
    pinMode(in1, OUTPUT);
    pinMode(in2, OUTPUT);
    pinMode(in3, OUTPUT);
    pinMode(in4, OUTPUT);

    Wire.begin();

    // 初始化 BME280
    if (!bme.begin(0x76)) {
        Serial.println("BME280 初始化失败！");
        while (1);
    }

    // 初始化 MPU6050
    initMPU6050();

    Serial.println("系统启动完成");
    motor(false);   // 确保初始电机停止
}

// ==========================================================
//  loop()
// ==========================================================
void loop() {
    // ----- 1. 抬升/放下检测（每 66ms 一次） -----
    if (millis() - lastDet >= 66) {
        float ax, ay, az;
        readAcc(ax, ay, az);
        float mag = sqrt(ax * ax + ay * ay + az * az);
        float change = abs(mag - lastAcc);

        // ===== 防抖逻辑 =====
        if (!lifted) {
            // 当前为放下状态，检测是否抬升
            if (change > 1.5 || mag > 1.8) {
                liftCnt++;
                if (liftCnt >= CNT_NEEDED) {
                    lifted = true;
                    liftCnt = 0;
                    Serial.println(">>> 机器人被快速抬起，车轮开始转动 <<<");
                }
            } else {
                liftCnt = 0;   // 条件不满足，重置计数
            }
        } else {
            // 当前为抬起状态，检测是否放下
            if (mag < 1.1 && change < 0.3) {
                dropCnt++;
                if (dropCnt >= CNT_NEEDED) {
                    lifted = false;
                    dropCnt = 0;
                    Serial.println(">>> 机器人被快速放下，车轮停止转动 <<<");
                }
            } else {
                dropCnt = 0;
            }
        }

        lastAcc = mag;
        lastDet = millis();
    }

    // ----- 2. 传感器数据显示（每 600ms 一次） -----
    if (millis() - lastDisp >= 600) {
        float ax, ay, az, gx, gy, gz;
        readAcc(ax, ay, az);
        readGyro(gx, gy, gz);

        // ---- BME280 数据 ----
        Serial.print("[BME280] ");
        Serial.print("温度：");
        Serial.print(bme.readTemperature(), 1);
        Serial.print("°C，湿度：");
        Serial.print(bme.readHumidity(), 1);
        Serial.print("%，气压：");
        Serial.print(bme.readPressure() / 100.0, 1);
        Serial.println(" hPa");

        // ---- MPU6050 数据 ----
        Serial.print("[MPU6050] ");
        Serial.print("加速度计：X=");
        Serial.print(ax, 2);
        Serial.print("g，Y=");
        Serial.print(ay, 2);
        Serial.print("g，Z=");
        Serial.print(az, 2);
        Serial.print("g | 陀螺仪：X=");
        Serial.print(gx, 1);
        Serial.print("°/s，Y=");
        Serial.print(gy, 1);
        Serial.print("°/s，Z=");
        Serial.print(gz, 1);
        Serial.println("°/s");

        Serial.println("---");   // 分隔线
        lastDisp = millis();
    }

    // ----- 3. 根据 lifted 状态控制电机 -----
    motor(lifted);
}
