#include <Wire.h>
#include <ADS1115_WE.h>

ADS1115_WE ads = ADS1115_WE(0x48);

// ====================================================
// 调试开关（注释掉关闭串口输出）
// ====================================================
#define DEBUG_SERIAL

// ====================================================
// 电机PWM引脚
// ====================================================
const int enablePin1 = 10;  // 右电机
const int enablePin2 = 9;   // 左电机

// ====================================================
// 电机方向引脚
// ====================================================
const int in1Pin = 4;
const int in2Pin = 5;
const int in3Pin = 2;
const int in4Pin = 3;

// ====================================================
// ADS1115阈值
// ====================================================
const int thresholds[3] = {
    15000,  // 左
    15000,  // 中（超前3cm）
    10900   // 右
};

// ====================================================
// 传感器状态
// ====================================================
int irSensorDigital[3];
int irSensors = B000;

// 原始ADC值（用于连续转向计算）
int rawLeft = 0, rawMid = 0, rawRight = 0;

// ====================================================
// 唯一速度参数 —— 直道巡航速度
// S弯较多时建议 50-60
// ====================================================
const int baseSpeed = 90;

// ====================================================
// 直角弯单轮支点转弯速度
// B011/B110 时一轮刹停、另一轮以此速度前进
// ====================================================
const int pivotSpeed = 70;

// ====================================================
// 死区阈值
// ====================================================
const int deadband = 8;

// ====================================================
// B000 交替搜索间隔 (ms)
// ====================================================
const unsigned long b000SweepInterval = 400;

// ====================================================
// B000 恢复后冷却期 (ms) —— 防止刚找回线又立即丢
// ====================================================
const unsigned long b000RecoveryCooldown = 300;

// ====================================================
// 统一 PID 参数（不再区分正常/直角弯模式）
// 稍高的 Ki 帮助 S 弯持续转向
// ====================================================
const float Kp = 0.70;
const float Ki = 0.015;
const float Kd = 2.5;

// ====================================================
// PID变量
// ====================================================
float error = 0;
float lastError = 0;
float integral = 0;
float derivative = 0;
float pid = 0;

// ====================================================
// B111 连续计数
// ====================================================
int consecutiveB111 = 0;

// ====================================================
// B000 搜索状态
// ====================================================
bool b000Active = false;
unsigned long b000StartTime = 0;
unsigned long lastB000Sweep = 0;
int b000SearchDir = 1;
unsigned long b000RecoveryTime = 0;  // 恢复冷却时间戳

// ====================================================
// 电机速度
// ====================================================
int leftMotorSpeed = 0;
int rightMotorSpeed = 0;

// ====================================================
// 读取ADS1115通道
// ====================================================
int readADS(byte ch) {
    static const ADS1115_MUX channels[3] = {
        ADS1115_COMP_0_GND,
        ADS1115_COMP_1_GND,
        ADS1115_COMP_2_GND
    };
    ads.setCompareChannels(channels[ch]);
    ads.startSingleMeasurement();
    while(ads.isBusy()) {}
    return ads.getRawResult();
}

// ====================================================
// 初始化
// ====================================================
void setup() {
    #ifdef DEBUG_SERIAL
    Serial.begin(115200);
    #endif

    pinMode(enablePin1, OUTPUT);
    pinMode(enablePin2, OUTPUT);
    pinMode(in1Pin, OUTPUT);
    pinMode(in2Pin, OUTPUT);
    pinMode(in3Pin, OUTPUT);
    pinMode(in4Pin, OUTPUT);

    Wire.begin();

    if(!ads.init()) {
        #ifdef DEBUG_SERIAL
        Serial.println("ADS1115 ERROR");
        #endif
        while(1);
    }

    ads.setVoltageRange_mV(ADS1115_RANGE_6144);
    ads.setConvRate(ADS1115_860_SPS);

    #ifdef DEBUG_SERIAL
    Serial.println("=== ADS1115 READY (v5 直角弯强化) ===");
    Serial.print("baseSpeed="); Serial.print(baseSpeed);
    Serial.print(" | Kp="); Serial.print(Kp);
    Serial.print(" Ki="); Serial.print(Ki);
    Serial.print(" Kd="); Serial.println(Kd);
    Serial.println("模式: Kp=0.70 pivot转弯 + 中传感器=0减速");
    Serial.println("==========================================");
    #endif

    StopMotors();
}

// ====================================================
// 主循环
// ====================================================
void loop() {
    Scan();
    CalculateError();
    PID_Control();
    Drive(leftMotorSpeed, rightMotorSpeed);
}

// ====================================================
// 扫描红外传感器
//
// 硬件布局（非对称，中间超前3cm）:
//         [左]    [右]     ← 两侧（基准位置）
//           \     /
//            \   /
//           [中间]         ← 中间（超前 ~3cm）
//
// 传感器位序: B[左][中][右]，1=黑线，0=白
// ====================================================
void Scan() {
    irSensors = B000;

    rawLeft  = readADS(2);
    rawMid   = readADS(1);
    rawRight = readADS(0);

    int raw[3] = {rawLeft, rawMid, rawRight};

    for(int i = 0; i < 3; i++) {
        irSensorDigital[i] = (raw[i] >= thresholds[i]) ? 1 : 0;
        irSensors |= (irSensorDigital[i] << (2 - i));
    }

    #ifdef DEBUG_SERIAL
    static unsigned long lastPrint = 0;
    if(millis() - lastPrint > 100) {
        Serial.print("L=");
        Serial.print(rawLeft);
        Serial.print(" M=");
        Serial.print(rawMid);
        Serial.print(" R=");
        Serial.print(rawRight);
        Serial.print(" | S=B");
        Serial.print(irSensors, BIN);
        Serial.print(" E=");
        Serial.print(error, 1);
        Serial.print(" | Lm=");
        Serial.print(leftMotorSpeed);
        Serial.print(" Rm=");
        Serial.print(rightMotorSpeed);

        if(irSensors == B000) {
            Serial.print(" | LOST ");
            if(b000Active) {
                Serial.print(millis() - b000StartTime);
                Serial.print("ms ");
                Serial.print(b000SearchDir > 0 ? "→" : "←");
            }
        } else if((irSensors == B101 || irSensors == B111) && consecutiveB111 <= 2) {
            Serial.print(" | TRANS");
        } else if(irSensors == B101 || irSensors == B111) {
            Serial.print(" | STRAIGHT");
        }

        Serial.println();
        lastPrint = millis();
    }
    #endif
}

// ====================================================
// 状态转误差（混合：连续ADC + 二进制状态）
//
// 核心改进: 在B111/B110/B011等状态下用原始ADC差值
// 做连续转向，解决"全黑时无方向信息"的根本问题。
//
// rawRight > rawLeft → 线偏右 → 正值误差 → 右转
// rawLeft > rawRight → 线偏左 → 负值误差 → 左转
//
// B100/B001 保留二进制强纠偏（极端情况）
// B000 保留交替搜索
// ====================================================
void CalculateError() {
    // 连续转向误差：基于左右传感器ADC原始差值
    // divisor=140 将 ±15000 差值映射到约 ±107 误差范围
    int continuousError = (rawRight - rawLeft) / 140;
    continuousError = constrain(continuousError, -110, 110);

    switch(irSensors) {
        case B010:
        case B110:
        case B011:
            // 使用连续ADC误差做精细转向
            error = continuousError;
            break;

        case B101:
        case B111:
            // B101/B111: 短时(≤2次) = 弯道过渡，维持lastError
            //            长时(>2次) = 直道，用连续ADC误差微调保持居中
            if(consecutiveB111 <= 2) {
                error = (abs(lastError) < 40) ? continuousError : lastError;
            } else {
                error = continuousError;
            }
            break;

        case B100:
            // 仅左传感器在线 → 严重偏右，强力左转（pivot）
            error = -95;
            break;

        case B001:
            // 仅右传感器在线 → 严重偏左，强力右转（pivot）
            error = 95;
            break;

        case B000:
            // 丢线：使用交替搜索方向
            if(b000Active) {
                error = b000SearchDir * 110;
            } else {
                if(abs(lastError) < 40) {
                    error = (lastError <= 0) ? -55 : 55;
                } else {
                    error = (lastError < 0) ? -110 : 110;
                }
            }
            break;

        default:
            error = continuousError;
    }
}

// ====================================================
// PID控制（统一模式，无直角弯特殊处理）
//
// S弯策略:
//   - B101/B111 合并处理，连续计数判断直道/弯道过渡
//   - B100/B001 硬编码 pivot 转弯
//   - B000 交替搜索，找回线后有冷却期防止再次丢线
//   - 速度根据误差幅度自动调节
// ====================================================
void PID_Control() {
    derivative = error - lastError;
    derivative = constrain(derivative, -30, 30);

    // ============================================
    // B101/B111 连续计数 + 直道稳定性修复
    //
    // 进入持续B101/B111（直道）时:
    //   1. 清零 derivative，消除弯道→直道切换时的剧烈甩动
    //   2. 清零 integral，消除弯道残留积分导致的直道漂移
    // ============================================
    if(irSensors == B101 || irSensors == B111) {
        consecutiveB111++;
        // 刚进入持续直道（第3次B101/B111）：清除弯道残留
        if(consecutiveB111 == 3) {
            derivative = 0;
            integral = 0;
        }
    } else {
        consecutiveB111 = 0;
    }

    // ============================================
    // B000 交替搜索 + 恢复冷却
    // ============================================
    bool inRecoveryCooldown = (millis() < b000RecoveryTime);

    if(irSensors == B000) {
        // 进入丢线状态
        if(!b000Active && !inRecoveryCooldown) {
            b000StartTime = millis();
            b000Active = true;
            lastB000Sweep = millis();
            b000SearchDir = (lastError <= 0) ? -1 : 1;
            integral = 0;  // 重置积分，避免历史值干扰搜索
            #ifdef DEBUG_SERIAL
            Serial.print(">>> B000 SEARCH START → ");
            Serial.println(b000SearchDir > 0 ? "RIGHT" : "LEFT");
            #endif
        }

        // 定时反转搜索方向
        if(b000Active && (millis() - lastB000Sweep > b000SweepInterval)) {
            b000SearchDir = -b000SearchDir;
            lastB000Sweep = millis();
            #ifdef DEBUG_SERIAL
            Serial.print(">>> B000 SWEEP REVERSE → ");
            Serial.println(b000SearchDir > 0 ? "RIGHT" : "LEFT");
            #endif
        }
    } else {
        // 找回线了
        if(b000Active) {
            #ifdef DEBUG_SERIAL
            Serial.print(">>> LINE FOUND! S=B");
            Serial.print(irSensors, BIN);
            Serial.println(" | cooldown 300ms");
            #endif
            b000RecoveryTime = millis() + b000RecoveryCooldown;
            integral = 0;
        }
        b000Active = false;
    }

    // ============================================
    // 积分累加
    // ============================================
    // 始终累加积分以帮助持续转向（直角弯需要积分辅助）
    //
    // 关键修复: error 正负变号说明机器人越过了中线，
    // 旧方向的积分会拖累新方向，必须清零。
    if((error > 0 && lastError < 0) || (error < 0 && lastError > 0)) {
        integral = 0;
    }
    // 大误差跳变时减半积分，避免剧烈抖动
    if(abs(derivative) > 40) {
        integral *= 0.5;
    }
    integral += error;
    integral = constrain(integral, -300, 300);

    // ============================================
    // 根据误差自动调整速度
    //
    // B100/B001: error=±110 → 需要足够基础速度做 pivot
    //   Kp=0.70, P项=77, baseSpeed=40 时:
    //   外轮=117 内轮=-37 → 一轮反转支点转弯
    // ============================================
    int currentBaseSpeed;
    int absErr = abs(error);

    if(absErr >= 110) {
        currentBaseSpeed = 40;   // 直角弯 pivot / 丢线搜索
    } else if(absErr >= 80) {
        currentBaseSpeed = 50;   // 严重偏离
    } else if(absErr >= 40) {
        currentBaseSpeed = 50;   // 一般弯道
    } else {
        currentBaseSpeed = baseSpeed;  // 直道 55
    }

    // ============================================
    // 中间传感器超前预警减速
    //
    // 中间传感器超前3cm，当它读到0（白）时说明
    // 前方黑线即将偏离或中断，提前减速以争取
    // 更多转向时间，使过弯更平滑。
    //
    // B000 时中间离线是预期丢线行为，
    // 需要速度做交替搜索，不应减速。
    // ============================================
    if(irSensorDigital[1] == 0
       && irSensors != B000) {
        currentBaseSpeed = min(currentBaseSpeed, 35);
    }

    // ============================================
    // PID计算
    // ============================================
    pid = Kp * error + Ki * integral + Kd * derivative;
    lastError = error;

    // ============================================
    // 计算电机速度
    // ============================================
    leftMotorSpeed  = constrain(currentBaseSpeed + pid, -255, 255);
    rightMotorSpeed = constrain(currentBaseSpeed - pid, -255, 255);

    // ============================================
    // 硬编码转向速度覆盖
    //
    // B011: 左离线、中右在线 → 绕右轮右转
    //       右轮刹停，左轮前进
    // B110: 左中在线、右离线 → 绕左轮左转
    //       左轮刹停，右轮前进
    // B001: 仅右在线 → 左轮前进，右轮刹停 pivot
    // B100: 仅左在线 → 右轮前进，左轮刹停 pivot
    // ============================================
    if(irSensors == B011) {
        leftMotorSpeed  =  pivotSpeed;
        rightMotorSpeed =  0;
    } else if(irSensors == B110) {
        leftMotorSpeed  =  0;
        rightMotorSpeed =  pivotSpeed;
    } else if(irSensors == B001) {
        leftMotorSpeed  = 50;
        rightMotorSpeed = -80;
    } else if(irSensors == B100) {
        leftMotorSpeed  = -80;
        rightMotorSpeed =50;
    }
}

// ====================================================
// 驱动电机
// ====================================================
void Drive(int leftSpeed, int rightSpeed) {
    // 右电机 (enablePin1, in1Pin, in2Pin)
    if(abs(rightSpeed) < deadband) {
        analogWrite(enablePin1, 0);
    } else if(rightSpeed > 0) {
        digitalWrite(in1Pin, HIGH);
        digitalWrite(in2Pin, LOW);
        analogWrite(enablePin1, rightSpeed);
    } else {
        digitalWrite(in1Pin, LOW);
        digitalWrite(in2Pin, HIGH);
        analogWrite(enablePin1, -rightSpeed);
    }

    // 左电机 (enablePin2, in3Pin, in4Pin)
    if(abs(leftSpeed) < deadband) {
        analogWrite(enablePin2, 0);
    } else if(leftSpeed > 0) {
        digitalWrite(in3Pin, HIGH);
        digitalWrite(in4Pin, LOW);
        analogWrite(enablePin2, leftSpeed);
    } else {
        digitalWrite(in3Pin, LOW);
        digitalWrite(in4Pin, HIGH);
        analogWrite(enablePin2, -leftSpeed);
    }
}

// ====================================================
// 停止电机
// ====================================================
void StopMotors() {
    digitalWrite(in1Pin, LOW);
    digitalWrite(in2Pin, LOW);
    digitalWrite(in3Pin, LOW);
    digitalWrite(in4Pin, LOW);
    analogWrite(enablePin1, 0);
    analogWrite(enablePin2, 0);
}
